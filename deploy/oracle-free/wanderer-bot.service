[Unit]
Description=Wanderer Discord Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=opc
WorkingDirectory=/opt/scara-wanderer-bots
Environment=APP_DIR=/opt/scara-wanderer-bots
EnvironmentFile=/opt/scara-wanderer-bots/deploy/oracle-free/wanderer.env
ExecStart=/opt/scara-wanderer-bots/deploy/oracle-free/launch_wanderer.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
